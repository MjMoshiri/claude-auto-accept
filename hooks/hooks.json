      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/judge.sh\"",
            "timeout": 30,
            "statusMessage": "Auto-accept: evaluating..."
          }
        ]
      }
    ],
    "PermissionRequest": [
